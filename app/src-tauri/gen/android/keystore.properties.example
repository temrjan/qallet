# Release signing configuration for Android builds.
# Copy this file to keystore.properties and fill in your values.
# NEVER commit keystore.properties to Git.

# Path to your keystore file (absolute or relative to gen/android/)
storeFile=/absolute/path/to/your-release.keystore

# Key alias inside the keystore
keyAlias=your-key-alias

# Password for both the keystore and the key.
# Using the same password for store and key is common for single-key keystores.
password=your-strong-password
